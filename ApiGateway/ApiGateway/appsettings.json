{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity" }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/users/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/users" }
        ]
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/products/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/products" }
        ]
      },
      "warranty-route": {
        "ClusterId": "warranty-cluster",
        "Match": {
          "Path": "/warranties/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/warranties" }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/notifications" }
        ]
      },
      "document-route": {
        "ClusterId": "document-cluster",
        "Match": {
          "Path": "/documents/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/documents" }
        ]
      },
      "reports-route": {
        "ClusterId": "reports-cluster",
        "Match": {
          "Path": "/reports/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/reports" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5119/"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5139/"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5085/"
          }
        }
      },
      "warranty-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5281/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5160/"
          }
        }
      },
      "document-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5291/"
          }
        }
      },
      "reports-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5270/"
          }
        }
      }
    }
  }
}
